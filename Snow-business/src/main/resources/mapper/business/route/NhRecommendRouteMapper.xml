<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.snow.business.route.mapper.NhRecommendRouteMapper">

    <resultMap type="com.snow.business.route.domain.NhRecommendRoute" id="NhRecommendRouteResult">
        <id     property="id"          column="id"           />
        <result property="routeDate"   column="route_date"   />
        <result property="spotName"    column="spot_name"    />
        <result property="subTitle"    column="sub_title"    />
        <result property="spotContent" column="spot_content" />
    </resultMap>

    <sql id="selectNhRecommendRouteVo">
        select id, route_date, spot_name, sub_title, spot_content
          from nh_recommend_route
    </sql>

    <select id="selectNhRecommendRouteById" parameterType="Long" resultMap="NhRecommendRouteResult">
        <include refid="selectNhRecommendRouteVo"/>
        where id = #{id}
    </select>

    <select id="selectNhRecommendRouteList" parameterType="com.snow.business.route.domain.NhRecommendRoute" resultMap="NhRecommendRouteResult">
        <include refid="selectNhRecommendRouteVo"/>
        <where>
            <if test="spotName != null and spotName != ''">
                and spot_name like concat('%', #{spotName}, '%')
            </if>
            <if test="startDate != null">
                and route_date &gt;= #{startDate}
            </if>
            <if test="endDate != null">
                and route_date &lt;= #{endDate}
            </if>
        </where>
        order by route_date desc, id desc
    </select>

    <insert id="insertNhRecommendRoute" parameterType="com.snow.business.route.domain.NhRecommendRoute" useGeneratedKeys="true" keyProperty="id">
        insert into nh_recommend_route
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="routeDate != null">route_date,</if>
            <if test="spotName != null and spotName != ''">spot_name,</if>
            <if test="subTitle != null">sub_title,</if>
            <if test="spotContent != null">spot_content,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="routeDate != null">#{routeDate},</if>
            <if test="spotName != null and spotName != ''">#{spotName},</if>
            <if test="subTitle != null">#{subTitle},</if>
            <if test="spotContent != null">#{spotContent},</if>
        </trim>
    </insert>

    <update id="updateNhRecommendRoute" parameterType="com.snow.business.route.domain.NhRecommendRoute">
        update nh_recommend_route
        <set>
            <if test="routeDate != null">route_date = #{routeDate},</if>
            <if test="spotName != null and spotName != ''">spot_name = #{spotName},</if>
            <if test="subTitle != null">sub_title = #{subTitle},</if>
            <if test="spotContent != null">spot_content = #{spotContent},</if>
        </set>
        where id = #{id}
    </update>

    <delete id="deleteNhRecommendRouteById" parameterType="Long">
        delete from nh_recommend_route where id = #{id}
    </delete>

    <delete id="deleteNhRecommendRouteByIds" parameterType="Long">
        delete from nh_recommend_route where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper>
