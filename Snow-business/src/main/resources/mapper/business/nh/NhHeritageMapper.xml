<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.snow.business.nh.mapper.NhHeritageMapper">

    <resultMap type="com.snow.business.nh.domain.NhHeritage" id="NhHeritageResult">
        <id     property="id"            column="id"             />
        <result property="heritageCode"  column="heritage_code"  />
        <result property="name"          column="name"           />
        <result property="category"      column="category"       />
        <result property="region"        column="region"         />
        <result property="level"         column="level"          />
        <result property="inheritor"     column="inheritor"      />
        <result property="description"   column="description"    />
        <result property="imagesJson"    column="images_json"    />
        <result property="status"        column="status"         />
        <result property="remark"        column="remark"         />
        <result property="coverImage"    column="cover_image"    />
        <result property="delFlag"       column="del_flag"       />
        <result property="createBy"      column="create_by"      />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"      column="update_by"      />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectNhHeritageVo">
        select id, heritage_code, name, category, region, level, inheritor,
               description, images_json, status, remark, cover_image, del_flag,
               create_by, create_time, update_by, update_time
          from nh_heritage
    </sql>

    <select id="selectNhHeritageById" parameterType="Long" resultMap="NhHeritageResult">
        <include refid="selectNhHeritageVo"/>
        where id = #{id} and del_flag = '0'
    </select>

    <select id="selectNhHeritageByHeritageCode" parameterType="String" resultMap="NhHeritageResult">
        <include refid="selectNhHeritageVo"/>
        where heritage_code = #{heritageCode}
          and del_flag = '0'
        limit 1
    </select>

    <select id="selectNhHeritageList" parameterType="com.snow.business.nh.domain.NhHeritage" resultMap="NhHeritageResult">
        <include refid="selectNhHeritageVo"/>
        <where>
            del_flag = '0'
            <if test="name != null and name != ''">
                and name like concat('%', #{name}, '%')
            </if>
            <if test="category != null and category != ''">
                and category = #{category}
            </if>
            <if test="region != null and region != ''">
                and region = #{region}
            </if>
            <if test="level != null and level != ''">
                and level = #{level}
            </if>
            <if test="status != null and status != ''">
                and status = #{status}
            </if>
            <if test="startTime != null">
                and create_time &gt;= #{startTime}
            </if>
            <if test="endTime != null">
                and create_time &lt;= #{endTime}
            </if>
        </where>
        order by create_time desc, id desc
    </select>

    <insert id="insertNhHeritage" parameterType="com.snow.business.nh.domain.NhHeritage" useGeneratedKeys="true" keyProperty="id">
        insert into nh_heritage
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="heritageCode != null and heritageCode != ''">heritage_code,</if>
            <if test="name != null and name != ''">name,</if>
            <if test="category != null and category != ''">category,</if>
            <if test="region != null and region != ''">region,</if>
            <if test="level != null and level != ''">level,</if>
            <if test="inheritor != null and inheritor != ''">inheritor,</if>
            <if test="description != null and description != ''">description,</if>
            <if test="imagesJson != null">images_json,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="remark != null">remark,</if>
            <if test="coverImage != null and coverImage != ''">cover_image,</if>
            <if test="delFlag != null and delFlag != ''">del_flag,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="heritageCode != null and heritageCode != ''">#{heritageCode},</if>
            <if test="name != null and name != ''">#{name},</if>
            <if test="category != null and category != ''">#{category},</if>
            <if test="region != null and region != ''">#{region},</if>
            <if test="level != null and level != ''">#{level},</if>
            <if test="inheritor != null and inheritor != ''">#{inheritor},</if>
            <if test="description != null and description != ''">#{description},</if>
            <if test="imagesJson != null">#{imagesJson},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="remark != null">#{remark},</if>
            <if test="coverImage != null and coverImage != ''">#{coverImage},</if>
            <if test="delFlag != null and delFlag != ''">#{delFlag},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            sysdate()
        </trim>
    </insert>

    <update id="updateNhHeritage" parameterType="com.snow.business.nh.domain.NhHeritage">
        update nh_heritage
        <set>
            <if test="heritageCode != null and heritageCode != ''">heritage_code = #{heritageCode},</if>
            <if test="name != null and name != ''">name = #{name},</if>
            <if test="category != null">category = #{category},</if>
            <if test="region != null">region = #{region},</if>
            <if test="level != null">level = #{level},</if>
            <if test="inheritor != null">inheritor = #{inheritor},</if>
            <if test="description != null">description = #{description},</if>
            <if test="imagesJson != null">images_json = #{imagesJson},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="coverImage != null">cover_image = #{coverImage},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = sysdate()
        </set>
        where id = #{id}
          and del_flag = '0'
    </update>

    <update id="updateNhHeritageStatus" parameterType="com.snow.business.nh.domain.NhHeritage">
        update nh_heritage
        <set>
            status = #{status},
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = sysdate()
        </set>
        where id = #{id}
          and del_flag = '0'
    </update>

    <update id="deleteNhHeritageById" parameterType="Long">
        update nh_heritage
           set del_flag = '2',
               update_time = sysdate()
         where id = #{id}
           and del_flag = '0'
    </update>

    <update id="deleteNhHeritageByIds" parameterType="Long">
        update nh_heritage
           set del_flag = '2',
               update_time = sysdate()
         where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
          and del_flag = '0'
    </update>

</mapper>
