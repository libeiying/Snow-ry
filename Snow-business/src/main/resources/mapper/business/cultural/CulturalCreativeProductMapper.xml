<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.snow.business.cultural.mapper.CulturalCreativeProductMapper">

    <resultMap type="com.snow.business.cultural.domain.CulturalCreativeProduct" id="CulturalCreativeProductResult">
        <id     property="id"           column="id"            />
        <result property="productCode"  column="product_code"  />
        <result property="title"        column="title"         />
        <result property="subTitle"     column="sub_title"     />
        <result property="categoryCode" column="category_code" />
        <result property="categoryName" column="category_name" />
        <result property="price"        column="price"         />
        <result property="marketPrice"  column="market_price"  />
        <result property="stock"        column="stock"         />
        <result property="salesCount"   column="sales_count"   />
        <result property="coverImage"   column="cover_image"   />
        <result property="imagesJson"   column="images_json"   />
        <result property="specJson"     column="spec_json"     />
        <result property="serviceJson"  column="service_json"  />
        <result property="reviewCount"  column="review_count"  />
        <result property="reviewScore"  column="review_score"  />
        <result property="sortOrder"    column="sort_order"    />
        <result property="status"       column="status"        />
        <result property="createTime"   column="create_time"   />
        <result property="updateTime"   column="update_time"   />
    </resultMap>

    <sql id="selectCulturalCreativeProductVo">
        select id, product_code, title, sub_title, category_code, category_name,
               price, market_price, stock, sales_count, cover_image, images_json,
               spec_json, service_json, review_count, review_score, sort_order, status,
               create_time, update_time
          from cultural_creative_products
    </sql>

    <select id="selectCulturalCreativeProductById" parameterType="Long" resultMap="CulturalCreativeProductResult">
        <include refid="selectCulturalCreativeProductVo"/>
        where id = #{id}
    </select>

    <select id="selectCulturalCreativeProductList" parameterType="com.snow.business.cultural.domain.CulturalCreativeProduct" resultMap="CulturalCreativeProductResult">
        <include refid="selectCulturalCreativeProductVo"/>
        <where>
            <if test="productCode != null and productCode != ''">
                and product_code = #{productCode}
            </if>
            <if test="title != null and title != ''">
                and title like concat('%', #{title}, '%')
            </if>
            <if test="categoryCode != null and categoryCode != ''">
                and category_code = #{categoryCode}
            </if>
            <if test="status != null and status != ''">
                and status = #{status}
            </if>
        </where>
        order by sort_order asc, update_time desc
    </select>
</mapper>
